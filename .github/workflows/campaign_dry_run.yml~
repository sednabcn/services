name: Email GitHub Campaign System (DRY-RUN)
on:
  push:
    branches: ["master"]
  workflow_dispatch:  # Optional: allows manual triggering

jobs:
  dry-run:
    runs-on: ubuntu-latest
    env:
      ALERT_EMAIL: alerts@modelphysmat.com
      TRACKING_DIR: tracking
      SCHEDULED_DIR: scheduled-campaigns
      TEMPLATES_DIR: campaign-templates
      CONTACTS_DIR: contacts

    steps:
      - uses: actions/checkout@v4
      
      - uses: actions/setup-python@v4
        with:
          python-version: "3.11"
      
      - name: Install Python dependencies
        run: |
          pip install --upgrade pip
          # Install basic dependencies that are likely to be needed
          pip install pandas requests python-docx openpyxl
          # Install from requirements.txt if it exists
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          else
            echo "No requirements.txt found, using basic dependencies"
          fi
      
      - name: Create directories if they don't exist
        run: |
          mkdir -p "$TEMPLATES_DIR"
          mkdir -p "$CONTACTS_DIR" 
          mkdir -p "$SCHEDULED_DIR"
          mkdir -p "$TRACKING_DIR"
          echo "Created necessary directories"
      
      - name: Create test data (if directories are empty)
        run: |
          # Create test contacts if contacts directory is empty
          if [ -z "$(ls -A $CONTACTS_DIR 2>/dev/null)" ]; then
            echo "Creating test contact data..."
            cat > "$CONTACTS_DIR/test_contacts.csv" << 'EOF'
          name,email,company
          John Doe,john.doe@example.com,Test Corp
          Jane Smith,jane.smith@example.com,Demo Inc
          Bob Johnson,bob.johnson@example.com,Sample LLC
          Alice Williams,alice.williams@example.com,Alpha Ltd
          Charlie Brown,charlie.brown@example.com,Beta Corp
          EOF
            echo "Test contacts created"
          fi
          
          # Create test campaign if scheduled directory is empty
          if [ -z "$(ls -A $SCHEDULED_DIR 2>/dev/null)" ]; then
            echo "Creating test campaign..."
            cat > "$SCHEDULED_DIR/welcome_campaign.txt" << 'EOF'
          Subject: Welcome to Our Service
          
          Hello {name},
          
          Welcome to our service! We're excited to have you on board.
          
          This is a test email campaign running in dry-run mode.
          
          Best regards,
          The Team
          EOF
            echo "Test campaign created"
          fi
      
      - name: Dry Run Campaign Processor
        run: |
          python utils/docx_parser.py \
            --templates "$TEMPLATES_DIR" \
            --contacts "$CONTACTS_DIR" \
            --scheduled "$SCHEDULED_DIR" \
            --tracking "$TRACKING_DIR" \
            --alerts "$ALERT_EMAIL" \
            --dry-run
      
      - name: Debug - List created files
        run: |
          echo "Files in current directory:"
          ls -la
          echo ""
          echo "Files in tracking directory:"
          if [ -d "$TRACKING_DIR" ]; then
            ls -la "$TRACKING_DIR"
          fi
          echo ""
          echo "Looking for log files:"
          find . -name "*.log" -type f 2>/dev/null || echo "No log files found"
          echo ""
          echo "Contents of any .log files found:"
          for logfile in *.log; do
            if [ -f "$logfile" ]; then
              echo "--- Contents of $logfile ---"
              cat "$logfile"
              echo "--- End of $logfile ---"
              echo ""
            fi
          done
      
      - name: Generate Campaign Summary
        run: |
          echo "## 📋 Dry-Run Campaign Summary" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**Campaign Execution Details:**" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          
          # Check if dryrun.log exists and has content
          if [ -f "dryrun.log" ] && [ -s "dryrun.log" ]; then
            echo "### 📊 Campaign Results" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "| Metric | Value |" >> $GITHUB_STEP_SUMMARY
            echo "|--------|-------|" >> $GITHUB_STEP_SUMMARY
            
            # Extract total contacts
            TOTAL_CONTACTS=$(grep "Total contacts loaded:" dryrun.log | head -1 | awk '{print $4}' || echo "0")
            echo "| Total Contacts | $TOTAL_CONTACTS |" >> $GITHUB_STEP_SUMMARY
            
            # Extract total campaigns
            TOTAL_CAMPAIGNS=$(grep "Total campaigns processed:" dryrun.log | head -1 | awk '{print $4}' || echo "0")
            echo "| Campaigns Processed | $TOTAL_CAMPAIGNS |" >> $GITHUB_STEP_SUMMARY
            
            # Extract run mode
            RUN_MODE=$(grep "Run mode:" dryrun.log | head -1 | awk '{print $3}' || echo "UNKNOWN")
            echo "| Run Mode | $RUN_MODE |" >> $GITHUB_STEP_SUMMARY
            
            echo "" >> $GITHUB_STEP_SUMMARY
            
            # Individual campaigns table
            if [ "$TOTAL_CAMPAIGNS" != "0" ]; then
              echo "### 📧 Individual Campaigns" >> $GITHUB_STEP_SUMMARY
              echo "" >> $GITHUB_STEP_SUMMARY
              echo "| Campaign | Recipients | Status |" >> $GITHUB_STEP_SUMMARY
              echo "|----------|------------|--------|" >> $GITHUB_STEP_SUMMARY
              
              # Parse campaign entries from log
              awk '
                /^Campaign:/ { 
                  campaign = $2; 
                  getline; 
                  if (/^Recipients:/) recipients = $2; 
                  getline; 
                  getline; 
                  if (/^Status:/) status = $2 " " $3 " " $4 " " $5; 
                  print "| " campaign " | " recipients " | " status " |"; 
                }
              ' dryrun.log >> $GITHUB_STEP_SUMMARY
            fi
            
            echo "" >> $GITHUB_STEP_SUMMARY
            
            # Sample recipients if available
            if grep -q "Sample recipients:" dryrun.log; then
              echo "### 👥 Sample Recipients (First 5)" >> $GITHUB_STEP_SUMMARY
              echo "" >> $GITHUB_STEP_SUMMARY
              echo '```' >> $GITHUB_STEP_SUMMARY
              grep "Sample recipients:" dryrun.log | head -1 | cut -d':' -f2- >> $GITHUB_STEP_SUMMARY
              echo '```' >> $GITHUB_STEP_SUMMARY
              echo "" >> $GITHUB_STEP_SUMMARY
            fi
            
          else
            echo "### ❌ No Campaign Results" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "| Status | Details |" >> $GITHUB_STEP_SUMMARY
            echo "|--------|---------|" >> $GITHUB_STEP_SUMMARY
            echo "| Log File | Not found or empty |" >> $GITHUB_STEP_SUMMARY
            echo "| Possible Issues | No campaigns scheduled or processing error |" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
          fi
          
          # Check for error log
          if [ -f "error.log" ] && [ -s "error.log" ]; then
            echo "### 🚨 Errors Encountered" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
            echo '```' >> $GITHUB_STEP_SUMMARY
            cat error.log >> $GITHUB_STEP_SUMMARY
            echo '```' >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
          fi
          
          # Add execution metadata
          echo "### 🔧 Execution Metadata" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Field | Value |" >> $GITHUB_STEP_SUMMARY
          echo "|-------|-------|" >> $GITHUB_STEP_SUMMARY
          echo "| Run ID | ${{ github.run_id }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Commit | ${{ github.sha }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Branch | ${{ github.ref_name }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Timestamp | $(date -u) |" >> $GITHUB_STEP_SUMMARY
          echo "| Runner | ${{ runner.os }} |" >> $GITHUB_STEP_SUMMARY
          
      - name: Upload logs as artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: campaign-logs
          path: |
            *.log
            tracking/
          retention-days: 7
